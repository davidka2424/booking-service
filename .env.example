# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=booking_db
POSTGRES_USER=booking_user
POSTGRES_PASSWORD=booking_pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Worker
TASK_FAILURE_PROBABILITY=0.15
TASK_MAX_RETRIES=3
TASK_RETRY_DELAY=5
